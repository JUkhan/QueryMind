# Copy to .env for local development, OR set these as Environment Variables
# in the Coolify UI (recommended for production — do not commit real secrets).

# Required: Google Gemini API key used by the AI chatbot.
GOOGLE_API_KEY=your_google_gemini_api_key

# Which database backend to use: sqlite | postgres | mssql
DB_SYSTEM=sqlite

# Only needed when DB_SYSTEM is postgres or mssql.
# postgres: postgresql://user:password@host:5432/dbname
# mssql:    mssql+pyodbc://user:password@host/dbname?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes
# DATABASE_URL=

# Optional schema name for postgres (default: public) / mssql (default: dbo).
# SCHEMA=

# Initial login user created on first boot when the DB is empty (no passwords —
# login matches username + email). Set SEED_DEFAULT_USER=0 to disable.
# SEED_USERNAME=testuser
# SEED_EMAIL=testuser@gmail.com
# SEED_DEFAULT_USER=1

# Load the demo dataset (customers/products/orders) from sample_data.sql on
# first boot so the chatbot has data to query. Set to 0 to disable.
# SEED_SAMPLE_DATA=1

# Where the SQLite file lives inside the container. In Coolify this is set to
# a persistent volume path by docker-compose; leave unset for local dev.
# SQLITE_PATH=/app/data/database.db
